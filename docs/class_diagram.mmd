classDiagram
    %% --- ARCHITECTURAL BASE ---
    class BaseController {
        <<abstract>>
        #reply(res: FastifyReply, data: any, code?: number): void
        #error(res: FastifyReply, error: Error): void
    }

    %% --- MODULAR STRUCTURE (Example Modules) ---
    %% Each module follows: Routes -> Controller -> Service -> Prisma

    class TechnologyModule {
        +TechnologyController
        +TechnologyService
        +TechnologyRepository
    }

    class ProjectModule {
        +ProjectController
        +ProjectService
    }

    class HostModule {
        +HostController
        +HostService
    }

    class UserModule {
        +UserController
        +UserService
    }

    %% --- SERVICES (Logic Layer) ---
    class TechnologyService {
        -repo: TechnologyRepository
        +getAll(query: any): Promise~Technology[]~
        +create(data: any): Promise~Technology~
        +update(id: string, data: any): Promise~Technology~
        +delete(id: string): Promise~void~
    }

    class ProjectService {
        -prisma: PrismaClient
        +listProjects(): Promise~Project[]~
        +assignContainer(projectId, containerId): Promise~void~
    }

    class HostService {
        -prisma: PrismaClient
        +listHosts(): Promise~Host[]~
        +addTechToHost(hostId, techId): Promise~void~
    }

    class AnalyticsService {
        +getDashboardStats(): Promise~DashboardDTO~
        -calculateMttr(): number
        -getSecurityPosture(): number
    }

    class IngestService {
        +processAgentPayload(payload: AgentData): Promise~void~
        -upsertInfrastructure(data: any): void
    }

    %% --- CONTROLLERS (API Layer) ---
    class TechnologyController {
        -service: TechnologyService
        +getTechnologies(req, res): void
        +postTechnology(req, res): void
    }

    class ProjectController {
        -service: ProjectService
        +getProjects(req, res): void
        +patchProject(req, res): void
    }

    class HostController {
        -service: HostService
        +getHosts(req, res): void
        +postHost(req, res): void
    }

    class AnalyticsController {
        -service: AnalyticsService
        +getMetrics(req, res): void
    }

    %% --- RELATIONSHIPS ---
    BaseController <|-- TechnologyController
    BaseController <|-- ProjectController
    BaseController <|-- HostController
    BaseController <|-- AnalyticsController
    BaseController <|-- UserController

    TechnologyController ..> TechnologyService : "uses"
    ProjectController ..> ProjectService : "uses"
    HostController ..> HostService : "uses"
    AnalyticsController ..> AnalyticsService : "uses"
    
    TechnologyService ..> Repository : "data access"
    ProjectService ..> PrismaClient : "direct access"
    HostService ..> PrismaClient : "direct access"