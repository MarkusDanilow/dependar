classDiagram
    %% --- BASE CLASSES (DRY Principle) ---
    class BaseController {
        <<abstract>>
        #sendSuccess(res: FastifyReply, data: any, statusCode?: number): void
        #handleError(res: FastifyReply, error: Error): void
    }

    class BaseRepository~T~ {
        <<abstract>>
        #prisma: PrismaClient
        +create(data: any): Promise~T~
        +findById(id: string): Promise~T~
        +findAll(query?: any): Promise~T[]~
        +update(id: string, data: any): Promise~T~
        +delete(id: string): Promise~T~
    }

    %% --- INTERFACES ---
    class IRepository~T~ {
        <<interface>>
        +create(data: any): Promise~T~
        +findById(id: string): Promise~T~
        +findAll(query?: any): Promise~T[]~
        +update(id: string, data: any): Promise~T~
        +delete(id: string): Promise~T~
    }

    class ITechnologyRepository {
        <<interface>>
        +findBySemVer(name: string, versionRange: string): Promise~Technology[]~
    }

    class IIngestionStrategy {
        <<interface>>
        +parsePayload(payload: any): ParsedTechDTO[]
    }

    %% --- REPOSITORIES (Data Access Layer) ---
    class UserRepository {
        +findByEmail(email: string): Promise~User~
    }
    class TechnologyRepository {
        +findBySemVer(name, versionRange)
    }
    class ContainerRepository {
        +findByHost(hostId: string): Promise~Container[]~
    }
    class VulnStateRepository {
        +getSecurityStats(): Promise~StatsDTO~
    }

    %% --- SERVICES (Business Logic Layer) ---
    class AuthService {
        -userRepo: UserRepository
        +login(credentials: LoginDTO): Promise~string~
    }
    class UserService {
        -userRepo: UserRepository
        +getUsers(): Promise~User[]~
    }
    class TechnologyService {
        -techRepo: TechnologyRepository
        +getAllTechnologies(): Promise~Technology[]~
    }
    class ContainerService {
        -containerRepo: ContainerRepository
        +getProjectsAndContainers(): Promise~Container[]~
    }
    class AnalyticsService {
        -vulnRepo: VulnStateRepository
        +getDashboardMetrics(): Promise~MetricsDTO~
    }
    class SettingsService {
        +getGlobalSettings(): Promise~SettingsDTO~
    }
    class IngestionService {
        -techRepo: ITechnologyRepository
        +processPayload(source: string, payload: any): Promise~void~
    }
    class GraphService {
        -techRepo: ITechnologyRepository
        +buildReactFlowData(): Promise~GraphDTO~
    }
    class AiChatService {
        -ollamaEndpoint: string
        +analyzeRiskContext(vulnStateId: string): Promise~AiInsight~
    }
    class CveSyncService {
        -techRepo: ITechnologyRepository
        +cronFetchDailyThreats(): void
    }

    %% --- CONTROLLERS (Presentation Layer) ---
    class AuthController {
        -authService: AuthService
        +postLogin(req, res): void
    }
    class UserController {
        -userService: UserService
        +getUsers(req, res): void
    }
    class TechnologyController {
        -techService: TechnologyService
        +getTechnologies(req, res): void
    }
    class ContainerController {
        -containerService: ContainerService
        +getContainers(req, res): void
    }
    class AnalyticsController {
        -analyticsService: AnalyticsService
        +getMetrics(req, res): void
    }
    class SettingsController {
        -settingsService: SettingsService
        +getSettings(req, res): void
    }
    class IngestionController {
        -ingestionService: IngestionService
        +postAgentData(req, res): void
    }
    class GraphController {
        -graphService: GraphService
        +getGraph(req, res): void
    }
    class AiChatController {
        -aiChatService: AiChatService
        +postMessage(req, res): void
    }

    %% --- RELATIONSHIPS ---
    IRepository <|.. BaseRepository
    BaseRepository <|-- UserRepository
    BaseRepository <|-- TechnologyRepository
    BaseRepository <|-- ContainerRepository
    BaseRepository <|-- VulnStateRepository
    ITechnologyRepository <|.. TechnologyRepository
    
    BaseController <|-- AuthController
    BaseController <|-- UserController
    BaseController <|-- TechnologyController
    BaseController <|-- ContainerController
    BaseController <|-- AnalyticsController
    BaseController <|-- SettingsController
    BaseController <|-- IngestionController
    BaseController <|-- GraphController
    BaseController <|-- AiChatController