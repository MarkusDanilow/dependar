{
  "name": "dependar-api",
  "version": "1.0.0",
  "description": "Dependar API (Fastify + Prisma)",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "vitest run",
    "test:unit": "vitest run src/modules/**/*.spec.ts",
    "test:integration": "vitest run src/modules/**/*.test.ts",
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@prisma/client": "^5.10.0",
    "bcrypt": "^6.0.0",
    "fastify": "^4.26.2",
    "node-cron": "^4.2.1",
    "ollama": "^0.6.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.3.1",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "prisma": "^5.10.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.3",
    "vitest": "^4.1.1",
    "vitest-mock-extended": "^3.1.0"
  }
}
